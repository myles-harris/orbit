# ─── Environment ───────────────────────────────────────────────────────────────
# NODE_ENV values: development | staging | production | test
NODE_ENV=development

# ─── Database ──────────────────────────────────────────────────────────────────
# Local dev:   postgresql://user:password@localhost:5432/orbit_dev
# Staging:     set automatically by Railway staging environment
# Test (CI):   postgresql://test:test@localhost:5432/orbit_test  (set in CI env)
DATABASE_URL=postgresql://user:password@localhost:5432/orbit_dev

# Server
PORT=3000

# JWT
JWT_SECRET=your-secret-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Twilio Verify (for OTP) ───────────────────────────────────────────────────
# Production: use your live Account SID + Auth Token from console.twilio.com
# Staging:    use TEST credentials from console.twilio.com → Account → Test Credentials
#             Test credentials look like AC... but do not send real SMS or charge.
#             Create a separate Verify Service in the test account for staging.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Daily.co Video ────────────────────────────────────────────────────────────
# Production: API key and domain from your production Daily.co workspace
# Staging:    Create a separate domain (e.g. orbit-staging.daily.co) in Daily dashboard
#             with its own API key — rooms are fully isolated between domains.
DAILY_API_KEY=your_daily_api_key
DAILY_DOMAIN=your-domain.daily.co

# Push Notifications
# Firebase Cloud Messaging (Android) - Using Firebase Admin SDK
GOOGLE_APPLICATION_CREDENTIALS=./credentials/firebase-service-account.json

# Apple Push Notification Service (iOS)
# Get these from Apple Developer Portal - see APNS_SETUP_GUIDE.md
APNS_KEY_ID=ABC123DEFG                                    # Your APNs Key ID (10 characters)
APNS_TEAM_ID=XYZ9876543                                   # Your Apple Team ID (10 characters)
APNS_KEY_PATH=./credentials/AuthKey_ABC123DEFG.p8         # Path to your .p8 key file
APNS_BUNDLE_ID=com.orbit.app                              # Your iOS app bundle identifier
APNS_PRODUCTION=false                                      # false = sandbox (dev/staging/TestFlight), true = production (App Store)

# Twilio SMS (for fallback notifications)
TWILIO_PHONE_NUMBER=+1234567890

# Scheduler
SCHEDULER_ENABLED=true

# Logging
LOG_LEVEL=info
