    "dotenv": "^16.4.5",
    "expo": "~54.0.30",
    "express": "^4.19.2",
    "firebase-admin": "^13.6.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "twilio": "^5.10.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.30",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "prisma": "^5.18.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
